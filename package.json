{
  "name": "myGrunt",
  "description": "My grunt setup to use for my projects",
  "repository": "repo",
  "readme": "readme.md",
  "dirs": {
    "tasks": "./grunt-tasks/",
    "task-options": "./grunt-tasks/options/",
    "devlayout": "layout/_dev/",
    "layout": "layout/",
    "devmedia": "media/_dev/",
    "media": "media/",
    "css": "libs/css/",
    "js": "js/",
    "bower": "bower_components"
  },
  "variables": {
    "require-js-main": "../app",
    "require-js-out": "app.min.js",
    "require-css-main": "app.css",
    "require-css-out": "app.min.css"
  },
  "require-paths": {
    "jquery": "jquery/dist/jquery"
  },
  "load-tasks-pattern": [
    "grunt-*",
    "rjs.js",
    "amdclean.js"
  ],
  "tasks": {
    "default": [
      "autoprefixer",
      "cssmin"
    ]
  },
  "engines": {
    "node": ">= 0.10.0"
  },
  "devDependencies": {
    "grunt": "~0.4.2",
    "load-grunt-config": "^0.13.0",
    "load-grunt-tasks": "^0.6.0",
    "grunt-autoprefixer": "~0.7.3",
    "grunt-contrib-cssmin": "*"
  }
}
